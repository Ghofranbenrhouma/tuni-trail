{
  "name": "tunitrail-backend",
  "version": "1.0.0",
  "description": "TuniTrail — Backend API REST (Node.js + Express + MySQL)",
  "main": "server.js",
  "scripts": {
    "start": "nodemon server.js",
    "dev": "node --watch server.js",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "db:seed:all": "sequelize-cli db:seed:all",
    "db:seed:undo:all": "sequelize-cli db:seed:undo:all",
    "db:setup": "sequelize-cli db:create && npm run db:migrate && npm run db:seed:all",
    "db:reset": "npm run db:seed:undo:all && npm run db:migrate:undo:all && npm run db:setup"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.20.0",
    "nodemon": "^3.1.14",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
